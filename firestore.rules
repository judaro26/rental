rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── Helper: check if current user is an admin ──────────────────────────
    function isAdmin() {
      return request.auth != null
          && exists(/databases/$(database)/documents/admins/$(request.auth.uid));
    }

    // ── Properties ────────────────────────────────────────────────────────
    // Public read (shown on index.html), admin-only write
    match /properties/{propId} {
      allow read:  if true;
      allow write: if isAdmin();
    }

    // ── Tenants ───────────────────────────────────────────────────────────
    // Tenants can read/write their own doc, but cannot change
    // admin-controlled fields (status, monthlyRent, leaseStart, leaseEnd, propertyId)
    match /tenants/{tenantId} {
      allow read:   if request.auth.uid == tenantId || isAdmin();
      allow create: if request.auth.uid == tenantId;
      allow update: if isAdmin()
                    || (request.auth.uid == tenantId
                        && !request.resource.data.diff(resource.data)
                              .affectedKeys()
                              .hasAny(['status','monthlyRent','leaseStart','leaseEnd','propertyId','propertyName']));
      allow delete: if isAdmin();
    }

    // ── Payments ──────────────────────────────────────────────────────────
    // Tenants can read their own payments (created by Netlify function / admin)
    // Only admin (and the create-payment-intent function via Admin SDK) can write
    match /payments/{paymentId} {
      allow read:   if request.auth != null
                    && (resource.data.tenantId == request.auth.uid || isAdmin());
      allow write:  if isAdmin();
    }

    // ── Documents ─────────────────────────────────────────────────────────
    // Tenants can read their own documents; admin uploads them
    match /documents/{docId} {
      allow read:   if request.auth != null
                    && (resource.data.tenantId == request.auth.uid || isAdmin());
      allow write:  if isAdmin();
    }

    // ── Maintenance Requests ──────────────────────────────────────────────
    // Tenants can create and read their own requests
    // Only admin can update status / add notes
    match /maintenanceRequests/{reqId} {
      allow read:   if request.auth != null
                    && (resource.data.tenantId == request.auth.uid || isAdmin());
      allow create: if request.auth != null
                    && request.resource.data.tenantId == request.auth.uid;
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }

    // ── Admins ────────────────────────────────────────────────────────────
    // Only admins can read the admins collection (used for isAdmin() check)
    match /admins/{adminId} {
      allow read:  if isAdmin();
      allow write: if isAdmin();
    }

    // ── Announcements ─────────────────────────────────────────────────────
    // Any authenticated user can read; only admin can write
    match /announcements/{announcementId} {
      allow read:  if request.auth != null;
      allow write: if isAdmin();
    }
  }
}
